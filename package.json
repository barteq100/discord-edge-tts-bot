{
  "name": "discord-edge-tts-bot",
  "version": "1.0.0",
  "description": "Free Discord TTS bot using Microsoft Edge neural TTS.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "register": "tsx src/register.ts"
  },
  "keywords": [
    "discord",
    "tts",
    "edge-tts",
    "text-to-speech"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@andresaya/edge-tts": "^1.8.0",
    "@discordjs/voice": "^0.19.0",
    "discord.js": "^14.22.1",
    "dotenv": "^17.2.3",
    "ffmpeg-static": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
